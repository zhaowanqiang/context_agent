# 复制为 .env.local 并填入 Supabase 项目凭据（Dashboard → Settings → API）

# 工作台访问码：私有层（/agent /monitor 等）需先输码登录（cookie 半年有效）。
# 公开层（首页/文章/关于/RSS）不受影响。不填则不验证（仅建议纯本机 127.0.0.1 使用时）。
ADMIN_ACCESS_CODE=

# 个人网站公开层：部署公网后填正式域名（canonical/OG/RSS/sitemap 用），本地不填默认 localhost:3000
# SITE_URL=https://example.com

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Python LLM 服务地址（默认本地 8600，一般不用改）
AGENT_API_URL=http://127.0.0.1:8600

# 外站源抓取代理（可选）：直连失败的源（Reddit/HN 等）经此代理走 curl 抓取
# AGENT_FETCH_PROXY=http://127.0.0.1:10808

# 全自动产线（可选）：定时 cron 表达式（默认每天 08:00；设 off 关闭）、
# 选题分数门槛（默认 8）、单次最多产出篇数（默认 2）
# AUTOPILOT_CRON=0 8 * * *
# AUTOPILOT_SCORE_MIN=8
# AUTOPILOT_MAX_RUNS=2

# 成稿质检发布线（可选，默认 7）：成稿自检分低于该值时，自动产线带着问题清单重写一次
# QUALITY_MIN=7

# 产线告警推手机（可选）：Telegram Bot。不配则只有本机 toast 通知。
# 1) Telegram 里找 @BotFather 发 /newbot 建 bot，拿到 token
# 2) 给自己的 bot 发一句话，然后浏览器开 https://api.telegram.org/bot<token>/getUpdates
#    从返回 JSON 里找 chat.id 填到 CHAT_ID
# 国内到 api.telegram.org 走 AGENT_FETCH_PROXY，需保证代理可用
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# 监控简报模块：外部（如 Cowork）访问 /api/monitor/* 时带的 x-monitor-token 头。
# 填一段随机字符串即可。站内简报产线不需要它，仅推送接口用。
MONITOR_INGEST_TOKEN=

# 监控简报定时生成（可选）：cron 表达式（默认每天 09:00，和产线 08:00 错开；设 off 关闭）。
# 检索走 Google News RSS，国内需 AGENT_FETCH_PROXY 代理可用。
# BRIEFING_CRON=0 9 * * *
